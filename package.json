{
  "name": "opencode-perplexity",
  "version": "1.0.0",
  "description": "OpenCode plugin to use Perplexity Pro models without API keys",
  "main": "dist/plugin.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npx esbuild src/plugin.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/opencode-perplexity.js --external:@opencode-ai/plugin",
    "dev": "tsc --watch",
    "setup": "npm run build && node dist/install.js",
    "unsetup": "node dist/uninstall.js"
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "opencode",
    "perplexity",
    "plugin",
    "ai"
  ],
  "license": "MIT"
}
